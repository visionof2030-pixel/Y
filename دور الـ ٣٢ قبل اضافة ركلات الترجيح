        function setCache(key, value) {
            localStorage.setItem(key, JSON.stringify({
                value,
                time: Date.now()
            }));
        }

        function getCache(key) {
            try {
                const raw = localStorage.getItem(key);
                if (!raw) return null;
                const parsed = JSON.parse(raw);
                if (Date.now() - parsed.time > CACHE_TIME) return null;
                return parsed.value;
            } catch { return null; }
